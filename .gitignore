# === n8n & Local Data ===
# Ignora todo o diretório de dados locais do n8n (banco SQLite, logs e configurações)
n8n_data/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.log
crash.journal
config

# === Python ===
# Ignora o ambiente virtual do Python
python/venv/
venv/
.venv/
env/

# Caches do Python e arquivos compilados
__pycache__/
python/app/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# === Environment Variables (Segurança Máxima) ===
# Ignora arquivos de configuração local com chaves e senhas
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# NÃO ignore o .env.example (ele serve de molde para outras pessoas configurarem o projeto)
!.env.example

# === OS & IDEs ===
# Arquivos de sistema e do VS Code locais (se houver)
.vscode/
.idea/
.DS_Store
Thumbs.db